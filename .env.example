# Copy to .env (gitignored) and fill in. Never commit real secrets (CLAUDE.md §2.7).

# Local Postgres (Docker Compose)
POSTGRES_USER=kicklens
POSTGRES_PASSWORD=kicklens
POSTGRES_DB=kicklens
# From the host (tests, scripts). Inside compose the host is `postgres`, not localhost.
DATABASE_URL=postgresql://kicklens:kicklens@localhost:5432/kicklens

# Provider keys (developer-registered; needed for T-002 / T-003 spikes)
API_FOOTBALL_KEY=
HIGHLIGHTLY_KEY=
SPORTSGAMEODDS_KEY=

# Neon (needed for T-007 spike / M8)
NEON_DATABASE_URL=
