# Local AI session scaffolding — not committed to the repo
/CLAUDE.md
/PROGRESS.md
/BUILD_LOG.md
/.claude/

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Local data + secrets
/data/
.env
.env.*
!.env.example

# Terraform — provider binaries (100s of MB) + state; init re-fetches them.
# Keep .terraform.lock.hcl (committed on purpose: it pins provider versions/hashes).
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
crash.log
crash.*.log

# Node / frontend build (belt-and-braces alongside apps/web/.gitignore)
node_modules/
